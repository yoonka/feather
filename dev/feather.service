[Unit]
Description=Feather Mail Server
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=root
Group=root
WorkingDirectory=/opt/feather
ExecStart=/opt/feather/bin/feather start
ExecStop=/opt/feather/bin/feather stop
Restart=on-failure
RestartSec=5

Environment=LANG=en_US.UTF-8
Environment=HOME=/opt/feather
Environment=RELEASE_NODE=feather@localhost
Environment=RELEASE_TMP=/opt/feather/tmp
Environment=FEATHER_CONFIG_FOLDER=/etc/feather

# Logging — stdout/stderr go to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=feather

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/feather /opt/feather
PrivateTmp=true

[Install]
WantedBy=multi-user.target
